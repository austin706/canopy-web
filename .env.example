# Canopy Web — Environment Variables
# Copy this file to .env and update values as needed

VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenWeatherMap — fallback only; production uses the weather Edge Function
VITE_OPENWEATHER_API_KEY=your-openweathermap-api-key

# Anthropic — fallback only; production uses the scan-equipment Edge Function
VITE_AI_API_KEY=your-anthropic-api-key
